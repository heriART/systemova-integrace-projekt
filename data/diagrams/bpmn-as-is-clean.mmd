flowchart TD
    subgraph HOST["Host"]
        H_Start(("Potřeba\nubytování"))
        H_GW{"Způsob\nrezervace?"}
        H_Pozadavek["Odeslání požadavku\nna rezervaci\n(telefon/e-mail)"]
        H_Online["Vytvoření online\nrezervace (web/OTA)"]
        H_Potvrzeni["Přijetí potvrzení\nrezervace"]
        H_Checkin["Příjezd\na check-in"]
        H_Pobyt["Pobyt\nv hotelu"]
        H_Checkout["Check-out"]
        H_End(("Konec"))

        H_Start --> H_GW
        H_GW -- "Přímý kontakt" --> H_Pozadavek
        H_GW -- "Online" --> H_Online
        H_Pozadavek --> H_Potvrzeni
        H_Online --> H_Potvrzeni
        H_Potvrzeni --> H_Checkin
        H_Checkin --> H_Pobyt
        H_Pobyt --> H_Checkout
        H_Checkout --> H_End
    end

    subgraph RECEPCE["Recepce"]
        R_Prijem["Příjem požadavku\nna rezervaci"]
        R_Overeni["Ověření dostupnosti\npokoje v PMS"]
        R_GW_Dost{"Pokoj\ndostupný?"}
        R_Alternativa["Nabídka alternativního\ntermínu/pokoje"]
        R_Excel["Manuální dohledání\nhosta v Excelu\n(lokální tabulky)"]
        R_GW_Host{"Host nalezen\nv Excelu?"}
        R_NovyZaznam["Ruční zapsání\nnového hosta\ndo Excel tabulky"]
        R_BezHistorie["Potvrzení bez znalosti\nhistorie a preferencí"]
        R_Potvrzeni["Potvrzení rezervace\nhostovi"]
        R_Checkin["Check-in hosta\n(bez profilu,\nbez preferencí)"]
        R_Checkout["Check-out hosta,\nvyúčtování"]
        R_ManualniEmail["Manuální odeslání\nděkovného e-mailu\n(Outlook)"]

        R_Prijem --> R_Overeni
        R_Overeni --> R_GW_Dost
        R_GW_Dost -- "Ne" --> R_Alternativa
        R_Alternativa --> R_Overeni
        R_GW_Dost -- "Ano" --> R_Excel
        R_Excel --> R_GW_Host
        R_GW_Host -- "Ne" --> R_NovyZaznam
        R_GW_Host -- "Ano" --> R_BezHistorie
        R_NovyZaznam --> R_Potvrzeni
        R_BezHistorie --> R_Potvrzeni
        R_Potvrzeni --> R_Checkin
        R_Checkin --> R_Checkout
        R_Checkout --> R_ManualniEmail
    end

    subgraph PMS["PMS Horesplus (lokální instance)"]
        P_Overeni["Kontrola dostupnosti\npokojů (pouze\nlokální hotel)"]
        P_Zaznam["Záznam rezervace\ndo PMS"]
        P_Checkout["Zpracování check-outu,\nvyúčtování"]
        P_Export["Manuální export dat\ndo účetního systému\n(1× denně)"]

        P_Checkout --> P_Export
    end

    subgraph CHM["Channel Manager (SiteMinder)"]
        CM_Prijem["Příjem online\nrezervace (web/OTA)"]
        CM_Predani["Předání rezervace\ndo PMS"]

        CM_Prijem --> CM_Predani
    end

    %% Mezilanové toky
    H_Pozadavek -.-> R_Prijem
    H_Online -.-> CM_Prijem
    CM_Predani -.-> R_Prijem
    R_Overeni -.-> P_Overeni
    P_Overeni -.-> R_GW_Dost
    R_Potvrzeni -.-> P_Zaznam
    R_Potvrzeni -.-> H_Potvrzeni
    R_Checkout -.-> P_Checkout
    R_ManualniEmail -.-> H_End

    style HOST fill:#fff2cc,stroke:#d6b656
    style RECEPCE fill:#dae8fc,stroke:#6c8ebf
    style PMS fill:#d5e8d4,stroke:#82b366
    style CHM fill:#f8cecc,stroke:#b85450
