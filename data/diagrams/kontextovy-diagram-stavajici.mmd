flowchart TD
    Host["👤 Host\n(individuální / firemní)"]
    OTA["🌐 OTA kanály\n(Booking.com, Expedia)"]
    ChM["Channel Manager\n(SiteMinder)"]
    Web["Webové stránky\nAurora Hotels"]
