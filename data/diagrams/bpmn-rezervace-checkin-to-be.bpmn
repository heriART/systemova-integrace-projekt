        <dc:Bounds x="660" y="145" width="130" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_H_Pobyt" bpmnElement="Task_H_Pobyt">
        <dc:Bounds x="830" y="145" width="120" height="50" />
      </bpmndi:BPMNShape>
