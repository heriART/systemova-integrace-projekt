        <dc:Bounds x="565" y="530" width="200" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_R_CRM" bpmnElement="Task_R_CRM">
        <dc:Bounds x="670" y="330" width="180" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GW_R_Host" bpmnElement="GW_R_Host" isMarkerVisible="true">
        <dc:Bounds x="880" y="330" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="933" y="357.5" width="74" height="27" />
