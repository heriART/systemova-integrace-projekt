      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Shape_Part_Recepce" bpmnElement="Part_Recepce" isHorizontal="true">
        <dc:Bounds x="160" y="290" width="1640" height="320" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_R_Prijem" bpmnElement="Task_R_Prijem">
        <dc:Bounds x="220" y="380" width="150" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_R_Overeni" bpmnElement="Task_R_Overeni">
        <dc:Bounds x="400" y="380" width="160" height="50" />
      </bpmndi:BPMNShape>
