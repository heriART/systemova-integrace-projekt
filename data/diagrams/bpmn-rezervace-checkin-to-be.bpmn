        <di:waypoint x="790" y="170" />
        <di:waypoint x="830" y="170" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_F_H8" bpmnElement="F_H8">
        <di:waypoint x="950" y="170" />
